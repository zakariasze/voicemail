# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Voicemail recording (REQUIRED from Phase 2 onward) ---
# Publicly accessible URL to the human-recorded .mp3
# Can be a Twilio Assets URL or any HTTPS host.
VOICEMAIL_RECORDING_URL=

# --- Webhooks ---
# Public HTTPS URL where this Flask app is reachable, e.g.
# https://abcd-1234.ngrok.app  (no trailing slash)
WEBHOOK_BASE_URL=

# --- HubSpot (used from Phase 3 onward) ---
HUBSPOT_API_KEY=
# Numeric ID of the HubSpot contact list to dial from.
HUBSPOT_LIST_ID=

# --- Dashboard (used in Phase 5) ---
DASHBOARD_PORT=5000

# --- SMS follow-up (PoC) ---
# When true, sends one SMS to the same number ~SMS_FOLLOWUP_DELAY_SECONDS
# after a call ending with outcome "Voicemail Left". Requires the
# TWILIO_FROM_NUMBER above to be SMS-capable (A2P 10DLC registered for
# US numbers).
SMS_FOLLOWUP_ENABLED=false
# Message body. Supports {first_name} and {last_name} placeholders,
# filled from the HubSpot contact row (blank if no contact id).
SMS_FOLLOWUP_BODY=Hi {first_name}, this is Kai — just left you a voicemail. Give me a call back when you have a minute. Thanks!
# Seconds to wait after the call ends before sending the SMS.
SMS_FOLLOWUP_DELAY_SECONDS=15

# --- Personalized AI intro (Phase 7) ---
# When true, scheduler renders an ElevenLabs "Hi Dr. {first_name} —" intro
# per contact and /voice plays it back-to-back with VOICEMAIL_RECORDING_URL.
# Falls back to the body-only recording when disabled, the firstname is
# missing/garbage, or rendering fails — so this is purely additive.
INTRO_ENABLED=false
ELEVENLABS_API_KEY=
# Voice ID for the cloned / chosen ElevenLabs voice that matches the
# voice on VOICEMAIL_RECORDING_URL. Cloning the voice from the existing
# recording is what makes the seam between intro and body invisible.
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
# Intro template. Supports {first_name} placeholder. The em-dash gives
# a natural pitch-fall + small pause before the human body recording.
VOICEMAIL_INTRO_TEMPLATE=Hi Dr. {first_name} —
# Bump to invalidate the audio cache after editing the template.
VOICEMAIL_INTRO_TEMPLATE_VERSION=1
# Local directory where rendered intro MP3s are cached. Served by the
# Flask app at /audio/<hash>.mp3, so WEBHOOK_BASE_URL must be reachable
# by Twilio.
AUDIO_CACHE_DIR=audio_cache

# --- Call forwarding ---
# When true, a human-answered call plays hold music then dials
# PRIORITY_NUMBER_1 and PRIORITY_NUMBER_2 simultaneously (10s timeout).
# If neither answers, PRIORITY_NUMBER_3 is tried as a fallback (20s timeout).
# The first number to answer is bridged; the others are hung up.
# Requires at least PRIORITY_NUMBER_1 and PRIORITY_NUMBER_2 to be set.
CALL_FORWARDING_ENABLED=false
# Publicly accessible URL of the hold music .mp3.
HOLD_RECORDING_URL=
# Dialed simultaneously for the first 10 seconds.
PRIORITY_NUMBER_1=
PRIORITY_NUMBER_2=
# Fallback — dialed only if #1 and #2 both fail to answer.
PRIORITY_NUMBER_3=
