# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Voicemail recording (REQUIRED from Phase 2 onward) ---
# Publicly accessible URL to the human-recorded .mp3
# Can be a Twilio Assets URL or any HTTPS host.
VOICEMAIL_RECORDING_URL=

# --- Live human pickup → transfer to closers ---
# Comma-separated E.164 numbers to ring simultaneously when a human
# (not a voicemail box) picks up. First closer to answer takes the call.
# Leave empty to disable transfer and silently hang up on human pickup.
CLOSER_NUMBERS=
# Optional public URL of the short "please hold..." .mp3 played to the
# practice while we ring the closers. Falls back to Twilio TTS if unset.
HOLD_RECORDING_URL=
# Optional public URL of the courteous goodbye .mp3 played if no closer
# picks up within TRANSFER_RING_TIMEOUT_SECONDS. Falls back to TTS.
GOODBYE_RECORDING_URL=
# Seconds the closers' phones ring before we give up (default 20).
TRANSFER_RING_TIMEOUT_SECONDS=20

# --- Voicemail follow-up SMS ---
# Sent automatically to the same number after a voicemail is left.
# Defaults to a short generic message if unset.
SMS_FOLLOWUP_BODY=

# --- Webhooks ---
# Public HTTPS URL where this Flask app is reachable, e.g.
# https://abcd-1234.ngrok.app  (no trailing slash)
WEBHOOK_BASE_URL=

# --- HubSpot (used from Phase 3 onward) ---
HUBSPOT_API_KEY=
# Numeric ID of the HubSpot contact list to dial from.
HUBSPOT_LIST_ID=

# --- Dashboard (used in Phase 5) ---
DASHBOARD_PORT=5000
